---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact">

  <div class="bg-school-navy py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-school-accent font-semibold text-sm uppercase tracking-wider mb-2">Unde ne găsiți</p>
      <h1 class="font-display text-4xl md:text-5xl font-black text-white">Contact</h1>
    </div>
  </div>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">

      <!-- Info -->
      <div>
        <h2 class="section-title mb-6">Informații de contact</h2>
        <div class="space-y-5">
          <div class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-school-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-school-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-school-navy">Adresă</div>
              <div class="text-gray-500 mt-1">Strada Ciocârliei 4<br/>Aleșd, 415100, Bihor</div>
            </div>
          </div>

          <div class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-school-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-school-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-school-navy">Telefon</div>
              <a href="tel:+40770320188" class="text-school-blue hover:text-school-accent transition-colors mt-1 block">+40 770 320 188</a>
            </div>
          </div>

          <div class="flex items-start gap-4 p-5 bg-white rounded-2xl shadow-sm">
            <div class="w-10 h-10 bg-school-accent/10 rounded-xl flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-school-accent" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-school-navy">Email</div>
              <a href="mailto:liceualesd@yahoo.com" class="text-school-blue hover:text-school-accent transition-colors mt-1 block">liceualesd@yahoo.com</a>
            </div>
          </div>

          <div class="p-5 bg-white rounded-2xl shadow-sm">
            <div class="font-semibold text-school-navy mb-3">Program secretariat</div>
            <div class="space-y-1 text-sm text-gray-600">
              <div class="flex justify-between"><span>Luni – Vineri</span><span class="font-medium text-school-navy">08:00 – 16:00</span></div>
              <div class="flex justify-between"><span>Sâmbătă – Duminică</span><span class="font-medium text-gray-400">Închis</span></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Map placeholder -->
      <div>
        <h2 class="section-title mb-6">Hartă</h2>
        <div class="bg-white rounded-2xl shadow-sm overflow-hidden h-96">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2706.5!2d22.3817!3d47.0514!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNDfCsDAzJzA1LjAiTiAyMsKwMjInNTQuMCJF!5e0!3m2!1sro!2sro!4v1234567890"
            width="100%"
            height="100%"
            style="border:0;"
            allowfullscreen=""
            loading="lazy"
            title="Locație Colegiul Tehnic Alexandru Roman Aleșd"
          ></iframe>
        </div>
        <p class="text-sm text-gray-400 mt-2">Strada Ciocârliei 4, Aleșd 415100</p>
      </div>

    </div>
  </section>

</BaseLayout>
