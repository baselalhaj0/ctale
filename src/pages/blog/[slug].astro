---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.excerpt} image={post.data.image}>

  <!-- Header -->
  <div class="bg-school-navy py-14">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <a href="/blog" class="inline-flex items-center gap-1 text-school-accent text-sm font-medium hover:gap-2 transition-all mb-6">
        ← Înapoi la anunțuri
      </a>
      {post.data.tags && (
        <div class="flex flex-wrap gap-2 mb-4">
          {post.data.tags.map((tag: string) => (
            <span class="text-xs bg-white/10 text-gray-300 px-3 py-1 rounded-full">{tag}</span>
          ))}
        </div>
      )}
      <h1 class="font-display text-3xl md:text-5xl font-black text-white leading-tight mb-4">
        {post.data.title}
      </h1>
      <time class="text-gray-400 text-sm">
        {post.data.date.toLocaleDateString('ro-RO', { day: 'numeric', month: 'long', year: 'numeric' })}
      </time>
    </div>
  </div>

  <!-- Featured image -->
  {post.data.image && (
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 -mt-8 mb-10">
      <img
        src={post.data.image}
        alt={post.data.title}
        class="w-full rounded-2xl shadow-xl aspect-video object-cover"
      />
    </div>
  )}

  <!-- Content -->
  <article class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-20">
    <div class="prose prose-lg prose-headings:font-display prose-headings:text-school-navy prose-a:text-school-blue prose-a:no-underline hover:prose-a:underline max-w-none">
      <Content />
    </div>

    <div class="mt-12 pt-8 border-t border-gray-200">
      <a href="/blog" class="btn-primary">← Toate anunțurile</a>
    </div>
  </article>

</BaseLayout>
