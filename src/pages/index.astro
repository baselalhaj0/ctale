---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 6);

const stats = [
  { number: "800+", label: "Elevi" },
  { number: "60+", label: "Cadre didactice" },
  { number: "30+", label: "Ani de activitate" },
  { number: "12+", label: "Specializări" },
];

const specializari = [
  {
    icon: "S1",
    titlu: "Tehnician operator roboti industriali",
    tip: "Profesional",
  },
  { icon: "S2", titlu: "Tehnician electrotehnist", tip: "Liceal" },
  { icon: "S3", titlu: "Tehnician in constructii", tip: "Liceal" },
  { icon: "S4", titlu: "Tehnician operator tehnica de calcul", tip: "Liceal" },
  { icon: "S5", titlu: "Clasele V-VIII", tip: "Gimnaziu" },
  { icon: "S6", titlu: "Clasa Pregatitoare", tip: "Primar" },
];
---

<BaseLayout title="Acasă">
  <!-- HERO -->
  <section
    class="relative bg-school-navy overflow-hidden min-h-[88vh] flex items-center"
  >
    <!-- Background geometric pattern -->
    <div class="absolute inset-0 opacity-10">
      <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern
            id="grid"
            width="60"
            height="60"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M 60 0 L 0 0 0 60"
              fill="none"
              stroke="white"
              stroke-width="1"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#grid)"></rect>
      </svg>
    </div>
    <!-- Accent blob -->
    <div
      class="absolute top-0 right-0 w-[600px] h-[600px] bg-school-blue rounded-full opacity-30 translate-x-1/2 -translate-y-1/4"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-school-accent rounded-full opacity-5 -translate-x-1/2 translate-y-1/2"
    >
    </div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24">
      <div class="max-w-3xl">
        <div
          class="inline-flex items-center gap-2 bg-school-accent/20 text-school-accent text-sm font-semibold px-4 py-2 rounded-full mb-6 animate-fadeUp"
        >
          <span class="w-2 h-2 bg-school-accent rounded-full"></span>
          Aleșd, Județul Bihor
        </div>
        <h1
          class="font-display text-5xl md:text-7xl font-black text-white leading-tight mb-6 animate-fadeUp delay-100"
        >
          Colegiul Tehnic<br />
          <span class="text-school-accent">"Alexandru Roman"</span>
        </h1>
        <p
          class="text-gray-300 text-xl leading-relaxed mb-10 max-w-xl animate-fadeUp delay-200"
        >
          Formăm profesioniști pentru viitor. Educație tehnică de calitate,
          proiecte Erasmus+ și un mediu modern de învățare.
        </p>
        <div class="flex flex-wrap gap-4 animate-fadeUp delay-300">
          <a href="/oferta-educationala" class="btn-primary text-base">
            Ofertă Educațională →
          </a>
          <a href="/blog" class="btn-outline text-base"> Noutăți & Anunțuri </a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div
      class="absolute bottom-0 left-0 right-0 bg-white/5 backdrop-blur-sm border-t border-white/10"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-2 md:grid-cols-4 divide-x divide-white/10">
          {
            stats.map((s) => (
              <div class="py-5 px-6 text-center">
                <div class="text-school-accent font-display font-black text-3xl">
                  {s.number}
                </div>
                <div class="text-gray-400 text-sm mt-0.5">{s.label}</div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </section>

  <!-- NOUTĂȚI -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="flex items-end justify-between mb-10">
      <div>
        <p
          class="text-school-accent font-semibold text-sm uppercase tracking-wider mb-1"
        >
          Ultima oră
        </p>
        <h2 class="section-title">Noutăți & Anunțuri</h2>
      </div>
      <a
        href="/blog"
        class="text-school-blue font-semibold text-sm hover:text-school-accent transition-colors hidden sm:block"
      >
        Vezi toate →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {
        posts.map((post, i) => (
          <a
            href={`/blog/${post.id}`}
            class={`card group ${i === 0 ? "md:col-span-2" : ""}`}
          >
            {post.data.image && (
              <div class="overflow-hidden aspect-video bg-school-light">
                <img
                  src={post.data.image}
                  alt={post.data.title}
                  class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                />
              </div>
            )}
            <div class="p-6">
              <time class="text-xs text-gray-400 font-medium">
                {post.data.date.toLocaleDateString("ro-RO", {
                  day: "numeric",
                  month: "long",
                  year: "numeric",
                })}
              </time>
              <h3 class="font-display font-bold text-school-navy text-lg mt-2 mb-2 group-hover:text-school-blue transition-colors leading-snug">
                {post.data.title}
              </h3>
              {post.data.excerpt && (
                <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">
                  {post.data.excerpt}
                </p>
              )}
              <span class="inline-flex items-center gap-1 text-school-blue text-sm font-semibold mt-4 group-hover:gap-2 transition-all">
                Citește mai mult <span>→</span>
              </span>
            </div>
          </a>
        ))
      }
    </div>

    <div class="text-center mt-8 sm:hidden">
      <a href="/blog" class="btn-primary">Vezi toate anunțurile</a>
    </div>
  </section>

  <!-- SPECIALIZĂRI -->
  <section class="bg-white py-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <p
          class="text-school-accent font-semibold text-sm uppercase tracking-wider mb-1"
        >
          Ce oferim
        </p>
        <h2 class="section-title">Specializări & Profile</h2>
        <p class="text-gray-500 mt-2 max-w-xl mx-auto">
          De la primar până la liceu tehnic, pregătim elevi pentru piața muncii
          și pentru examenele naționale.
        </p>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {
          specializari.map((spec) => (
            <div class="group p-6 rounded-2xl border-2 border-gray-100 hover:border-school-blue hover:bg-school-light transition-all duration-200 cursor-default">
              <div class="text-4xl mb-4">{spec.icon}</div>
              <span class="text-xs font-semibold text-school-accent uppercase tracking-wider bg-school-accent/10 px-2 py-1 rounded-full">
                {spec.tip}
              </span>
              <h3 class="font-semibold text-school-navy mt-3 leading-snug">
                {spec.titlu}
              </h3>
            </div>
          ))
        }
      </div>

      <div class="text-center mt-10">
        <a href="/oferta-educationala" class="btn-primary">
          Ofertă educațională completă →
        </a>
      </div>
    </div>
  </section>

  <!-- ERASMUS BANNER -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div
      class="bg-gradient-to-r from-school-navy to-school-blue rounded-3xl p-10 md:p-14 flex flex-col md:flex-row items-center gap-8 relative overflow-hidden"
    >
      <div
        class="absolute right-0 top-0 opacity-10 text-[200px] leading-none font-black text-white select-none"
      >
        E+
      </div>
      <div class="flex-1 relative">
        <span
          class="text-school-accent font-semibold text-sm uppercase tracking-wider"
          >Program European</span
        >
        <h2
          class="font-display text-3xl md:text-4xl font-black text-white mt-2 mb-4"
        >
          Erasmus+ la CT Aleșd
        </h2>
        <p class="text-gray-300 leading-relaxed">
          Elevii noștri participă la mobilități în Italia, Spania și alte țări
          europene prin programul Erasmus+ KA122 VET. Experiențe internaționale
          care deschid cariere.
        </p>
      </div>
      <div class="shrink-0">
        <a href="/proiecte" class="btn-primary text-base whitespace-nowrap">
          Proiecte Erasmus+ →
        </a>
      </div>
    </div>
  </section>

  <!-- CONTACT QUICK -->
  <section class="bg-school-light py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="section-title mb-3">Ai întrebări?</h2>
      <p class="text-gray-500 mb-8">
        Suntem disponibili pentru orice informații despre înscrieri, programe
        sau activități școlare.
      </p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="tel:+40770320188"
          class="flex items-center gap-2 bg-white border-2 border-gray-200 hover:border-school-blue px-6 py-4 rounded-xl font-semibold text-school-navy transition-all hover:shadow-md"
        >
          <svg
            class="w-5 h-5 text-school-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
          +40 770 320 188
        </a>
        <a
          href="mailto:liceualesd@yahoo.com"
          class="flex items-center gap-2 bg-white border-2 border-gray-200 hover:border-school-blue px-6 py-4 rounded-xl font-semibold text-school-navy transition-all hover:shadow-md"
        >
          <svg
            class="w-5 h-5 text-school-accent"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
            ></path>
          </svg>
          liceualesd@yahoo.com
        </a>
        <a
          href="/contact"
          class="flex items-center gap-2 bg-school-navy text-white px-6 py-4 rounded-xl font-semibold transition-all hover:bg-school-blue hover:shadow-md"
        >
          Pagina de contact →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
